# ─────────────────────────────────────────────────────────────────────────────
# Dstyle environment variables
#
# Local dev: copy this file to `.env` and fill in real values.
# Vercel:    add every variable below in Project → Settings → Environment
#            Variables, then REDEPLOY (env changes don't affect existing builds).
#
# ⚠️  `.env` is gitignored, so it is NOT deployed — Vercel only has what you add
#     in its dashboard. A missing DATABASE_URL is why the store shows "0 pieces".
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (REQUIRED — without this the store shows no products) ────────────
# On Vercel (serverless) you MUST use Neon's POOLED connection string — the host
# has "-pooler" in it. The direct/non-pooled URL exhausts connections and fails.
# Neon dashboard → Connect → turn ON "Connection pooling" → copy that string.
#   direct : ...@ep-xxxx.<region>.aws.neon.tech/neondb?sslmode=require
#   pooled : ...@ep-xxxx-pooler.<region>.aws.neon.tech/neondb?sslmode=require   ← use this on Vercel
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.<region>.aws.neon.tech/neondb?sslmode=require"

# ── Auth (REQUIRED for login) ────────────────────────────────────────────────
# On Vercel, set these to your deployed domain, e.g. https://your-app.vercel.app
# Sign-in is email magic-link only (via Resend, below) — no Google/Twilio
# needed. NEXTAUTH_SECRET must be a real generated secret, not this placeholder.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ── AI (Groq) — powers the stylist + admin insights ──────────────────────────
# https://console.groq.com/keys  (unset → keyword stylist / rule-based insights)
GROQ_API_KEY="gsk_..."
# GROQ_MODEL="llama-3.3-70b-versatile"

# ── App URLs — set to the Vercel domain in production ─────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
ADMIN_EMAIL="admin@dstyle.in"

# ── Payments (Razorpay) ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="your-razorpay-key-id"

# ── Image uploads (Cloudinary) — admin product photos ────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── Email (Resend) — REQUIRED: this is how customers sign in ────────────────
# https://resend.com/api-keys (free tier). Without a real key, the sign-in
# modal shows "Couldn't send the sign-in link" — login is otherwise dead.
RESEND_API_KEY="your-resend-api-key"
FROM_EMAIL="noreply@dstyle.in"

# ── SMS / WhatsApp (optional, dormant) ───────────────────────────────────────
# Phone-OTP sign-in is coded but not shown in the UI. Add real Twilio creds
# and re-add the phone step to AuthModal.tsx to bring it back.
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"
INTERAKT_API_KEY="your-interakt-api-key"

# ── Redis (Upstash) — rate limiting / cache (optional) ───────────────────────
UPSTASH_REDIS_REST_URL="your-upstash-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
